# Порт (на Beget Nginx по умолчанию проксирует на 3000)
PORT=3000
NODE_ENV=production

# MySQL
DB_HOST=localhost
DB_USER=rusk_user
DB_PASSWORD=your_password
DB_NAME=rusk
DB_PORT=3306

# JWT
JWT_SECRET=long_random_secret_string

# Публичный URL сайта (для ссылок в письмах)
BACKEND_PUBLIC_URL=https://your-domain.beget.app

# Загрузки картинок меню (необязательно)
# UPLOADS_DIR=/var/www/html/backend/uploads

# Почта (когда настроите SMTP)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# MAIL_FROM=
